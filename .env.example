# Kisan Saathi - Environment Variables
# ─────────────────────────────────────
# Copy this file, rename it to .env, and fill in your keys.
#
# Get a FREE Groq key (recommended - no daily limits):
#   https://console.groq.com → API Keys → Create API Key
#
# Get a FREE Gemini key (backup):
#   https://aistudio.google.com/app/apikey

GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
